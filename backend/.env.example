# ================================================================
# DCPRIME 입학테스트 관리 시스템 - 환경변수 설정
# 이 파일을 복사해서 .env 로 저장 후 값을 채워넣으세요.
# cp .env.example .env
# ================================================================


# ── AI API 키 ──────────────────────────────────────────────────
# Anthropic (Claude) 또는 xAI (Grok) 중 하나 이상 필수
ANTHROPIC_API_KEY=
XAI_API_KEY=


# ── 데이터베이스 ───────────────────────────────────────────────
# PostgreSQL 연결 문자열
DATABASE_URL=postgresql://dcprime:dcprime1234@localhost:5432/dcprime


# ── NAS 경로 설정 ──────────────────────────────────────────────
# [기본 방식] NAS_ROOT 하나만 설정하면 하위 폴더 자동 파생
#   채점완료  → {NAS_ROOT}/채점완료
#   미채점    → {NAS_ROOT}/미채점/단어시험  /  미채점/입학테스트
#   오류      → {NAS_ROOT}/미채점오류
#   미매칭    → {NAS_ROOT}/미매칭
NAS_ROOT=/app/nas

# [개별 설정 방식] 각 폴더 경로를 직접 지정 (NAS_ROOT 무시됨)
# 나스 마운트 구조가 다를 경우 아래 값을 직접 지정
UNGRADED_WORD=/app/nas/미채점/단어시험
UNGRADED_ENTRANCE=/app/nas/미채점/입학테스트
GRADED=/app/nas/채점완료
ERROR_DIR=/app/nas/미채점오류
UNMATCHED_DIR=/app/nas/미매칭


# ── 로컬 경로 ──────────────────────────────────────────────────
# NAS 장애 대비 로컬 백업 저장 경로
UPLOAD_DIR=/app/uploads
LOCAL_BACKUP=/app/uploads/graded


# ── 한글 폰트 경로 (PDF 채점 결과 생성 시 사용) ────────────────
# Docker 이미지에 fonts-nanum 설치 시 기본값 자동 사용
# 커스텀 폰트 사용 시 아래 경로 지정 (.ttf 파일)
# KOREAN_FONT_PATH=/usr/share/fonts/truetype/nanum/NanumGothic.ttf
